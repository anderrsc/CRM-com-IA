# =====================================================
# MARQUINHOS OS CRM - Variáveis de Ambiente
# =====================================================
# Copie este arquivo para .env para rodar localmente
# No Vercel: configure em Project Settings > Environment Variables
# NUNCA commite o arquivo .env no git!

# URL da API no ambiente local (deixe vazio no Vercel)
VITE_API_BASE_URL=

# Porta do servidor local
API_PORT=8787

# Origem permitida para CORS no servidor local
APP_ORIGIN=http://127.0.0.1:5173

# =====================================================
# SUPABASE (obrigatório para persistência de dados)
# Pegue em: supabase.com > seu projeto > Settings > API
# =====================================================
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# =====================================================
# OPENAI (opcional - a IA tem fallback sem a chave)
# Pegue em: platform.openai.com/api-keys
# =====================================================
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# =====================================================
# META WHATSAPP CLOUD API (opcional)
# Configure em: developers.facebook.com
# =====================================================
WHATSAPP_GRAPH_VERSION=v23.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TOKEN=
WHATSAPP_VERIFY_TOKEN=marquinhos-webhook-token-2024
WHATSAPP_AUTO_REPLY=false
